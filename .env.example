# Database
DATABASE_URL="postgres://tesajor:tesajor@localhost:5433/tesajor"

# Auth.js
AUTH_SECRET="generate-with: openssl rand -base64 33"
AUTH_URL="http://localhost:3000"

# Google OAuth
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Telegram (see README for @BotFather setup steps). Leave TELEGRAM_BOT_TOKEN
# unset to disable Telegram sign-in/payment requests entirely.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
TELEGRAM_WEBHOOK_SECRET="generate-with: openssl rand -hex 32"

# Google Maps (optional — needs a GCP project with billing enabled).
# Leave unset and the trip-agenda map falls back to a plain stop list;
# "navigate to next stop" and live-position nearest-stop work regardless,
# since those need no API key at all.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=""

# Cloudinary (optional — file uploads: avatars, receipts, payment QR
# codes). Leave unset and uploads are written to ./public/uploads on the
# local disk instead. All three must be set together to enable it.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
